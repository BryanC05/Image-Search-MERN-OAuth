# Server Configuration
NODE_ENV=development
PORT=5000

# Session Security - REQUIRED: Generate a strong random secret
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/image-search

# OAuth Credentials - Get from respective developer consoles
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/api/auth/google/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=/api/auth/facebook/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=/api/auth/github/callback

# Unsplash API
UNSPLASH_ACCESS_KEY=

# Client URL (comma-separated for multiple environments)
CLIENT_URL=http://localhost:3000

# Optional: CA Certificate for MongoDB TLS
CA_CERT_PATH=
